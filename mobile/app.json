{
  "expo": {
    "name": "Zonemate",
    "slug": "zonemate-mobile",
    "scheme": "zonemate",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "io.zonemate.mobile.mjkim",
      "entitlements": {
        "com.apple.developer.family-controls": true
      }
    },
    "//": "Family Controls 엔타이틀먼트 + SHIELD_ENABLED가 켜진 상태(ios-focus-shield 브랜치). 서명하려면 Family Controls capability를 붙일 수 있는 유료 Apple Developer 계정이 필요하다. 무료 계정으로는 코드사인 단계에서 막힌다.",
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-notifications",
      "expo-secure-store",
      "expo-web-browser",
      [
        "expo-build-properties",
        {
          "ios": { "deploymentTarget": "16.0" }
        }
      ]
    ]
  }
}
