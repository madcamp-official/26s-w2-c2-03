GEMINI_API_KEY=xxxxxxxx
PORT=4000
APP_BASE_URL=http://localhost:5173
API_BASE_URL=http://localhost:4000

# 세션 JWT 서명용 — 아무 랜덤 문자열로 교체
JWT_SECRET=change-me-to-a-random-string

# 구글 OAuth (Google Cloud Console > API 및 서비스 > 사용자 인증 정보)
# 승인된 리디렉션 URI에 http://localhost:4000/api/auth/google/callback 등록 필요
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# 카카오 로그인 (Kakao Developers > 내 애플리케이션 > 카카오 로그인)
# Redirect URI에 http://localhost:4000/api/auth/kakao/callback 등록 필요
# 카카오 계정 이메일을 받으려면 "카카오 로그인 > 동의항목"에서 이메일 항목 활성화 필요
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=

# 이메일 인증코드 발송 (resend.com, 무료 티어로 시작 가능)
RESEND_API_KEY=
# Resend에서 인증한 도메인의 발신 주소. 예: Zonemate <noreply@zonemate.app>
# 비워 두면 테스트용 onboarding@resend.dev를 사용하며 Resend 계정 소유자에게만 보낼 수 있습니다.
RESEND_FROM_EMAIL=
