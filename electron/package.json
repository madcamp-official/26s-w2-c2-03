{
  "name": "zonemate-desktop",
  "productName": "Zonemate",
  "version": "0.1.17",
  "private": true,
  "author": "Zonemate Team",
  "description": "Zonemate desktop focus assistant",
  "repository": "https://github.com/madcamp-official/26s-w2-c2-03",
  "main": "main.js",
  "type": "commonjs",
  "scripts": {
    "start": "electron .",
    "smoke:windows": "set \"ELECTRON_RUN_AS_NODE=\" && set \"ELECTRON_SMOKE_TEST=1\" && electron .",
    "build:resources": "npm --prefix ../frontend run build && node scripts/prepare-package.js",
    "package:windows": "npm run build:resources && electron-forge package --platform=win32 --arch=x64",
    "make:windows": "npm run build:resources && electron-forge make --platform=win32 --arch=x64 && node scripts/copy-installer.js",
    "package:mac": "npm run build:resources && electron-forge package --platform=darwin",
    "make:mac": "npm run build:resources && electron-forge make --platform=darwin && node scripts/copy-mac-artifacts.js"
  },
  "dependencies": {
    "@mapbox/node-pre-gyp": "^2.0.3",
    "electron-squirrel-startup": "^1.0.1",
    "get-windows": "^9.3.0",
    "update-electron-app": "^3.3.0"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-dmg": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.2",
    "@electron-forge/publisher-github": "^7.11.2",
    "electron": "^43.1.0"
  },
  "allowScripts": {
    "electron@43.1.0": true,
    "electron-winstaller@5.4.4": true,
    "get-windows@9.3.0": true
  }
}
